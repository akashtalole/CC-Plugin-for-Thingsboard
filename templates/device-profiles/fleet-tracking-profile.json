        "alarmType": "Over Speed",
        "createRules": {
          "CRITICAL": {
            "schedule": {
              "type": "ANY_TIME"
            },
            "condition": {
              "spec": {
                "type": "SIMPLE"
              },
              "condition": [
                {
                  "key": {
                    "type": "TIME_SERIES",
                    "key": "speed"
                  },
                  "valueType": "NUMERIC",
                  "predicate": {
                    "type": "NUMERIC",
                    "operation": "GREATER",
                    "value": {
                      "defaultValue": 120,
                      "userValue": null
                    },
                    "dynamicValue": null
                  }
                }
              ]
            },
            "alarmDetails": ""
          }
        },
        "clearRule": {
          "schedule": {
            "type": "ANY_TIME"
          },
          "condition": {
            "spec": {
              "type": "SIMPLE"
            },
            "condition": [
              {
                "key": {
                  "type": "TIME_SERIES",
                  "key": "speed"
                },
                "valueType": "NUMERIC",
                "predicate": {
                  "type": "NUMERIC",
                  "operation": "LESS_OR_EQUAL",
                  "value": {
                    "defaultValue": 100,
                    "userValue": null
                  },
                  "dynamicValue": null
                }
              }
            ]
          }
        },
        "propagate": false,
